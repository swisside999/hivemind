{
  "name": "hivemind",
  "version": "0.1.0",
  "private": true,
  "description": "Orchestrate multiple Claude Code CLI sessions as a virtual software company",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter ./packages/server dev",
    "dev:web": "pnpm --filter ./packages/web dev",
    "build": "pnpm -r build",
    "build:server": "pnpm --filter ./packages/server build",
    "build:web": "pnpm --filter ./packages/web build",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "executionEnv": {
      "nodeVersion": "22.15.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
