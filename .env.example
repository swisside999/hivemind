# Hivemind Configuration
# Copy this file to .env and adjust values as needed.

# Server port for the Express REST API
HIVEMIND_PORT=3100

# WebSocket port for real-time updates to the GUI
# HIVEMIND_WS_PORT=3101

# Directory where user projects are stored
# HIVEMIND_PROJECTS_DIR=./projects

# Log level: debug | info | warn | error
HIVEMIND_LOG_LEVEL=info
